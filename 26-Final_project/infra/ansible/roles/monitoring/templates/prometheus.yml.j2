global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  - job_name: prometheus
    static_configs:
      - targets: ['localhost:9090']

  - job_name: trainings-tracker-node
    static_configs:
      - targets: ['{{ app_private_ip }}:9100']

  - job_name: trainings-tracker-app
    static_configs:
      - targets: ['{{ app_private_ip }}:{{ app_port }}']
    metrics_path: /api/metrics
