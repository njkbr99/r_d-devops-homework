server:
  http_listen_port: 9080
  grpc_listen_port: 0

positions:
  filename: /tmp/positions.yaml

clients:
  - url: http://{{ monitoring_private_ip }}:3100/loki/api/v1/push

scrape_configs:
  - job_name: trainings-tracker
    static_configs:
      - targets:
          - localhost
        labels:
          job: trainings-tracker
          host: app
          __path__: /var/lib/docker/containers/*/*-json.log
    pipeline_stages:
      - json:
          expressions:
            output: log
            stream: stream
      - output:
          source: output
