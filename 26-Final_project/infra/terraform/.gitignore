# Local Terraform state (we use S3 backend)
.terraform/
.terraform.lock.hcl
terraform.tfstate
terraform.tfstate.backup

# Variables file with secrets — never commit this
terraform.tfvars

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Plan output files
*.tfplan
